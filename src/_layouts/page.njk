---
layout: base.njk
---

    <article class="hentry">
      <div class="entry-content">
        {{ content | safe }}
        <footer class="entry-meta">
        {% if page.modified %}{{ title }} was last modified on <span class="entry-date date modified"><time datetime="{{ page.modified }}">{{ page.modified }}</time></span>
          <span class="author vcard fn">{{ site.owner.name }}</span>{% endif %}
        </footer>
      </div>
    </article>

